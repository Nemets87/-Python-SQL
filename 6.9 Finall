# 2. Класс для получения курсов (копия get_live_rates с теми же XPath)
# --------------------------------------------------------------
class ExchangeRateFetcher:
    """Парсер курсов USD/RUB и EUR/RUB. Использует проверенные локаторы."""
    URL = "https://yandex.ru/search/?text=%D0%BA%D1%83%D1%80%D1%81+usd+%D0%BA+%D1%80%D1%83%D0%B1%D0%BB%D1%8E&lr=39&clid=2261451&win=620"
    GECKODRIVER_PATH = r"C:\WebDriver\geckodriver.exe"

    # Локаторы, которые работали в исходном коде
    SWITCHER_XPATH = "/html/body/main/div[1]/div[3]/div/div/div[1]/ul/li[2]/div/article/div[1]/div[1]/span/button"
    OPTION_USD_XPATH = "/html/body/main/div[1]/div[3]/div/div/div[1]/ul/li[2]/div/article/div[1]/div[1]/span/div/div/div[2]/div/div[1]"
    OPTION_EUR_XPATH = "/html/body/main/div[1]/div[3]/div/div/div[1]/ul/li[2]/div/article/div[1]/div[1]/span/div/div/div[3]/div/div[1]"
    INPUT_XPATH = "/html/body/main/div[1]/div[3]/div/div/div[1]/ul/li[2]/div/article/div[1]/div[2]/div/span/input"
    CANCEL_BTN_XPATH = "/html/body/main/div[2]/div/div/div[2]/div/div/div/div[3]/button"
    ROBOT_CANCEL_XPATH = "/html/body/div[1]/div/main/div/form/div[3]/div/div[1]/div[1]"

    def __init__(self, headless=False, use_local_driver=True):
        self.headless = headless
        self.use_local_driver = use_local_driver
        self.driver = None

    def _start_browser(self):
        options = Options()
        if self.headless:
            options.add_argument('--headless')
        options.add_argument("--disable-blink-features=AutomationControlled")
        options.set_preference("dom.webnotifications.enabled", False)
        options.set_preference("dom.push.enabled", False)
        options.set_preference(
            "general.useragent.override",
            "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:130.0) Gecko/20100101 Firefox/130.0"
        )
        if self.use_local_driver:
            service = Service(executable_path=self.GECKODRIVER_PATH)
            self.driver = webdriver.Firefox(options=options, service=service)
        else:
            self.driver = webdriver.Firefox(options=options)
        print("🟢 Браузер успешно запущен.")

    def _remove_overlays(self):
        overlays = self.driver.find_elements(By.XPATH,
            "//*[contains(@class,'DistributionSplashScreenModalAddonBefore') or "
            "contains(@class,'modal') or contains(@class,'popup') or "
            "@role='dialog']"
        )
        for overlay in overlays:
            if overlay.is_displayed() and 'HeaderForm' not in overlay.get_attribute('class'):
                self.driver.execute_script("arguments[0].style.display = 'none';", overlay)
                # Логирование скрытых элементов оставлено для отладки

    def _detect_captcha(self):
        captcha_locators = [
            "//iframe[contains(@src,'captcha')]",
            "//div[contains(@class,'smart-captcha')]",
            "//div[@id='captcha']",
            "//input[@type='checkbox' and contains(@class,'CheckboxCaptcha')]"
        ]
        for locator in captcha_locators:
            try:
                self.driver.find_element(By.XPATH, locator)
                return True
            except:
                pass
        return False

    def _fetch_single_rate(self, currency):
        wait = WebDriverWait(self.driver, 20)
        # Используем точные рабочие локаторы из исходного кода
        switcher = wait.until(EC.element_to_be_clickable((By.XPATH, self.SWITCHER_XPATH)))
        current_text = switcher.text.strip()
        print(f"  🔄 Текущая кнопка: {current_text}")

        if currency not in current_text.upper():
            print(f"  🔄 Переключаю на {currency}...")
            switcher.click()
            time.sleep(random.uniform(0.5, 0.8))
            self._remove_overlays()
            time.sleep(0.3)

            option_xpath = self.OPTION_USD_XPATH if currency == 'USD' else self.OPTION_EUR_XPATH
            option = wait.until(EC.element_to_be_clickable((By.XPATH, option_xpath)))
            try:
                option.click()
            except ElementClickInterceptedException:
                print("  ⚠️ Клик перехвачен! Скрываю окна...")
                self._remove_overlays()
                time.sleep(0.5)
                option = wait.until(EC.element_to_be_clickable((By.XPATH, option_xpath)))
                self.driver.execute_script("arguments[0].click();", option)

            # Ожидаем обновления текста кнопки
            wait.until(lambda d: currency in d.find_element(By.XPATH, self.SWITCHER_XPATH).text.upper())
            print(f"  ✅ Кнопка теперь: {self.driver.find_element(By.XPATH, self.SWITCHER_XPATH).text}")
        else:
            print(f"  ✅ Валюта {currency} уже выбрана.")

        # Поле ввода курса
        print("  🔄 Ожидаю значение курса...")
        wait.until(lambda d: d.find_element(By.XPATH, self.INPUT_XPATH).get_attribute('value') != '')
        rate_str = self.driver.find_element(By.XPATH, self.INPUT_XPATH).get_attribute('value')
        print(f"  🎯 Сырое значение: '{rate_str}'")
        rate_str = rate_str.replace(',', '.').replace(' ', '')
        return float(rate_str)

    def get_rates(self):
        try:
            self._start_browser()
            self.driver.get(self.URL)
            wait = WebDriverWait(self.driver, 20)

            time.sleep(random.uniform(2, 4))
            self.driver.execute_script("window.scrollTo(0, document.body.scrollHeight/2);")
            time.sleep(random.uniform(0.5, 1.5))

            # Проверка на капчу
            print("🧹 Проверяю, не появилась ли капча...")
            if self._detect_captcha():
                print("❌ Обнаружена капча! Скриншот сохранён. Переключаюсь на резервные курсы.")
                self.driver.save_screenshot("captcha_detected.png")
                return None

            # Этап очистки
            print("🧹 Закрываю рекламные окна...")
            try:
                cancel_btn = wait.until(EC.element_to_be_clickable((By.XPATH, self.CANCEL_BTN_XPATH)))
                cancel_btn.click()
                time.sleep(0.5)
            except:
                pass
            try:
                robot_cancel = wait.until(EC.element_to_be_clickable((By.XPATH, self.ROBOT_CANCEL_XPATH)))
                robot_cancel.click()
                time.sleep(0.5)
            except:
                pass
            self._remove_overlays()
            time.sleep(0.5)

            print("🟢 Приступаю к получению курсов...")
            usd_rub = self._fetch_single_rate('USD')
            eur_rub = self._fetch_single_rate('EUR')
            print(f"🟢 Итог: USD/RUB={usd_rub}, EUR/RUB={eur_rub}")
            return {'USD_RUB': usd_rub, 'EUR_RUB': eur_rub}

        except Exception as e:
            print(f"❌ Ошибка в процессе: {e}")
            if self.driver:
                self.driver.save_screenshot("error_final.png")
            return None
        finally:
            if self.driver:
                self.driver.quit()
                print("🟢 Закрываю браузер.")

