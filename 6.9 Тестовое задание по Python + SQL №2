## 🪙 Полный код обменного пункта

```python
import sqlite3

# --------------------------------------------------------------
# 1. Инициализация базы данных и таблицы
# --------------------------------------------------------------
DB_NAME = 'exchanger.db'

with sqlite3.connect(DB_NAME) as db:
    cur = db.cursor()
    # Создаём таблицу с балансами пользователя
    cur.execute("""
        CREATE TABLE IF NOT EXISTS users_balance (
            UserID INTEGER PRIMARY KEY AUTOINCREMENT,
            Balance_RUB FLOAT NOT NULL,
            Balance_USD FLOAT NOT NULL,
            Balance_EUR FLOAT NOT NULL
        );
    """)
    # Проверяем, есть ли уже пользователь (с любым ID)
    cur.execute("SELECT COUNT(*) FROM users_balance")
    if cur.fetchone()[0] == 0:
        # Добавляем начального пользователя с балансами: RUB=100000, USD=1000, EUR=1000
        cur.execute(
            "INSERT INTO users_balance (Balance_RUB, Balance_USD, Balance_EUR) VALUES (?, ?, ?)",
            (100000.0, 1000.0, 1000.0)
        )
        print("✅ База данных создана. Начальный баланс установлен.")
    else:
        print("✅ База данных уже существует. Начальный баланс не изменён.")

# --------------------------------------------------------------
# 2. Функции для работы с балансом
# --------------------------------------------------------------
def get_balances(user_id=1):
    """Возвращает словарь с балансами пользователя."""
    with sqlite3.connect(DB_NAME) as db:
        cur = db.cursor()
        cur.execute("SELECT Balance_RUB, Balance_USD, Balance_EUR FROM users_balance WHERE UserID = ?", (user_id,))
        row = cur.fetchone()
        if row:
            return {'RUB': row[0], 'USD': row[1], 'EUR': row[2]}
        else:
            return None

def update_balance(user_id, currency, amount):
    """Изменяет баланс по валюте на указанную сумму (amount может быть отрицательным)."""
    with sqlite3.connect(DB_NAME) as db:
        cur = db.cursor()
        # Безопасное обновление с параметрами
        if currency == 'RUB':
            cur.execute("UPDATE users_balance SET Balance_RUB = Balance_RUB + ? WHERE UserID = ?", (amount, user_id))
        elif currency == 'USD':
            cur.execute("UPDATE users_balance SET Balance_USD = Balance_USD + ? WHERE UserID = ?", (amount, user_id))
        elif currency == 'EUR':
            cur.execute("UPDATE users_balance SET Balance_EUR = Balance_EUR + ? WHERE UserID = ?", (amount, user_id))

# --------------------------------------------------------------
# 3. Основная логика обмена
# --------------------------------------------------------------
def exchange_currency():
    """Одна операция обмена валюты."""
    print("\n" + "=" * 50)
    print("  Добро пожаловать в наш обменный пункт!")
    print("  Курс валют следующий:")
    print("    1 USD = 70 RUB")
    print("    1 EUR = 80 RUB")
    print("    1 USD = 0.87 EUR")
    print("    1 EUR = 1.15 USD")
    print("=" * 50)

    # Словарь курсов: для каждой пары (из_валюты, в_валюту) – коэффициент
    rates = {
        ('USD', 'RUB'): 70.0,
        ('EUR', 'RUB'): 80.0,
        ('RUB', 'USD'): 1/70.0,
        ('RUB', 'EUR'): 1/80.0,
        ('USD', 'EUR'): 0.87,
        ('EUR', 'USD'): 1.15
    }

    # Шаг 1. Выбор целевой валюты (которую хотим получить)
    print("\nВведите какую валюту желаете получить:")
    print("1. RUB")
    print("2. USD")
    print("3. EUR")
    target_choice = input("Ваш выбор (1/2/3): ").strip()
    target_map = {'1': 'RUB', '2': 'USD', '3': 'EUR'}
    if target_choice not in target_map:
        print("❌ Неверный выбор валюты!")
        return
    target_currency = target_map[target_choice]

    # Шаг 2. Сумма целевой валюты
    try:
        amount = float(input(f"Какая сумма Вас интересует ({target_currency})? "))
        if amount <= 0:
            print("❌ Сумма должна быть положительным числом!")
            return
    except ValueError:
        print("❌ Некорректный ввод суммы!")
        return

    # Шаг 3. Выбор валюты, которую отдаём
    print("\nКакую валюту готовы предложить взамен?")
    currencies = ['RUB', 'USD', 'EUR']
    for i, cur in enumerate(currencies, 1):
        print(f"{i}. {cur}")
    source_choice = input("Ваш выбор (1/2/3): ").strip()
    source_map = {'1': 'RUB', '2': 'USD', '3': 'EUR'}
    if source_choice not in source_map:
        print("❌ Неверный выбор валюты!")
        return
    source_currency = source_map[source_choice]

    # Проверка на одинаковые валюты
    if source_currency == target_currency:
        print("❌ Нельзя обменять одинаковые валюты!")
        return

    # Шаг 4. Расчёт необходимой суммы исходной валюты
    pair = (source_currency, target_currency)
    if pair not in rates:
        print(f"❌ Обмен {source_currency} -> {target_currency} не поддерживается!")
        return
    rate = rates[pair]
    required_amount = amount * rate  # сколько нужно отдать исходной валюты

    # Получаем текущие балансы
    balances = get_balances()
    if balances is None:
        print("❌ Не удалось получить баланс!")
        return

    source_balance = balances[source_currency]
    print(f"\nДля получения {amount} {target_currency} необходимо {required_amount:.2f} {source_currency}.")
    print(f"Ваш текущий баланс {source_currency}: {source_balance:.2f}")

    if source_balance < required_amount:
        print(f"❌ Недостаточно средств! Не хватает {required_amount - source_balance:.2f} {source_currency}.")
        return

    # Шаг 5. Выполнение обмена
    # Снимаем required_amount исходной валюты, добавляем amount целевой
    update_balance(1, source_currency, -required_amount)
    update_balance(1, target_currency, amount)

    print(f"\n✅ Обмен успешно выполнен!")
    new_balances = get_balances()
    print("Ваш новый баланс:")
    for cur, bal in new_balances.items():
        print(f"  {cur}: {bal:.2f}")

# --------------------------------------------------------------
# 4. Главный цикл программы
# --------------------------------------------------------------
def main():
    print("🏦 Обменный пункт готов к работе.")
    while True:
        exchange_currency()
        again = input("\nХотите совершить ещё один обмен? (y/n): ").strip().lower()
        if again != 'y':
            print("👋 Спасибо, что воспользовались нашим обменным пунктом! До свидания.")
            break

if __name__ == "__main__":
    main()
```

