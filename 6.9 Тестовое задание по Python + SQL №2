```python
import sqlite3

DB_NAME = 'exchanger.db'

# --------------------------------------------------------------
# 1. Инициализация базы данных и таблицы
# --------------------------------------------------------------
with sqlite3.connect(DB_NAME) as db:
    cur = db.cursor()
    cur.execute("""
        CREATE TABLE IF NOT EXISTS users_balance (
            UserID INTEGER PRIMARY KEY AUTOINCREMENT,
            Balance_RUB REAL NOT NULL,
            Balance_USD REAL NOT NULL,
            Balance_EUR REAL NOT NULL
        );
    """)
    # Если таблица пуста – добавляем начального пользователя с балансами
    cur.execute("SELECT COUNT(*) FROM users_balance")
    if cur.fetchone()[0] == 0:
        cur.execute(
            "INSERT INTO users_balance (Balance_RUB, Balance_USD, Balance_EUR) VALUES (?, ?, ?)",
            (100000.0, 1000.0, 1000.0)
        )
        print("✅ База данных создана, начальный баланс зачислен.")
    else:
        print("✅ База данных уже существует.")

# --------------------------------------------------------------
# 2. Функция для получения баланса
# --------------------------------------------------------------
def get_balances(user_id=1):
    """Возвращает словарь с текущими балансами пользователя."""
    with sqlite3.connect(DB_NAME) as db:
        cur = db.cursor()
        cur.execute("SELECT Balance_RUB, Balance_USD, Balance_EUR FROM users_balance WHERE UserID = ?", (user_id,))
        row = cur.fetchone()
        if row:
            return {'RUB': row[0], 'USD': row[1], 'EUR': row[2]}
        else:
            return None

# --------------------------------------------------------------
# 3. Основная операция обмена
# --------------------------------------------------------------
def exchange_operation():
    """Проводит одну операцию обмена валюты с проверками."""
    print("\n" + "=" * 50)
    print("  Добро пожаловать в наш обменный пункт!")
    print("  Курс валют следующий:")
    print("    1 USD = 70 RUB")
    print("    1 EUR = 80 RUB")
    print("    1 USD = 0,87 EUR")
    print("    1 EUR = 1,15 USD")
    print("=" * 50)

    # Словарь курсов: (исходная, целевая) → коэффициент.
    # Коэффициент означает, сколько исходной валюты нужно отдать за 1 единицу целевой.
    rates = {
        ('RUB', 'USD'): 70.0,
        ('RUB', 'EUR'): 80.0,
        ('USD', 'RUB'): 1/70.0,
        ('EUR', 'RUB'): 1/80.0,
        ('USD', 'EUR'): 1/0.87,   # ≈1.1494
        ('EUR', 'USD'): 1/1.15    # ≈0.8696
    }

    # Шаг 1. Выбор целевой валюты (которую хотим получить)
    print("\nВведите какую валюту желаете получить:")
    print("1. RUB")
    print("2. USD")
    print("3. EUR")
    target_choice = input("Ваш выбор (1/2/3): ").strip()
    currency_map = {'1': 'RUB', '2': 'USD', '3': 'EUR'}
    if target_choice not in currency_map:
        print("❌ Неверный номер валюты!")
        return
    target = currency_map[target_choice]

    # Шаг 2. Сумма целевой валюты
    try:
        amount = float(input(f"Какая сумма Вас интересует ({target})? "))
        if amount <= 0:
            print("❌ Сумма должна быть больше нуля!")
            return
    except ValueError:
        print("❌ Некорректное число!")
        return

    # Шаг 3. Выбор валюты, которую отдаём
    print("\nКакую валюту готовы предложить взамен?")
    print("1. RUB")
    print("2. USD")
    print("3. EUR")
    source_choice = input("Ваш выбор (1/2/3): ").strip()
    if source_choice not in currency_map:
        print("❌ Неверный номер валюты!")
        return
    source = currency_map[source_choice]

    # Нельзя обменивать одинаковые валюты
    if source == target:
        print("❌ Нельзя обменять одинаковые валюты!")
        return

    # Шаг 4. Расчёт необходимой суммы исходной валюты
    pair = (source, target)
    if pair not in rates:
        print(f"❌ Обмен {source} на {target} не поддерживается!")
        return
    rate = rates[pair]
    required = amount * rate   # столько нужно отдать валюты source

    # Получаем текущий баланс
    balances = get_balances()
    if not balances:
        print("❌ Не удалось получить данные о балансе!")
        return

    current_source_balance = balances[source]
    print(f"\nДля получения {amount:.2f} {target} необходимо {required:.2f} {source}.")
    print(f"Ваш текущий баланс {source}: {current_source_balance:.2f}")

    if current_source_balance < required:
        print(f"❌ Недостаточно средств! Не хватает {required - current_source_balance:.2f} {source}.")
        return

    # Шаг 5. Проведение обмена в одной транзакции
    with sqlite3.connect(DB_NAME) as db:
        cur = db.cursor()
        # Списываем исходную валюту
        cur.execute(f"UPDATE users_balance SET Balance_{source} = Balance_{source} - ? WHERE UserID = 1", (required,))
        # Зачисляем целевую валюту
        cur.execute(f"UPDATE users_balance SET Balance_{target} = Balance_{target} + ? WHERE UserID = 1", (amount,))
    print("✅ Обмен успешно выполнен!")

    # Вывод нового баланса
    new_balances = get_balances()
    print("Обновлённый баланс:")
    for cur_name, bal in new_balances.items():
        print(f"  {cur_name}: {bal:.2f}")

# --------------------------------------------------------------
# 4. Главный цикл программы
# --------------------------------------------------------------
def main():
    print("🏦 Обменный пункт готов к работе.")
    while True:
        exchange_operation()
        again = input("\nХотите совершить ещё один обмен? (y/n): ").strip().lower()
        if again != 'y':
            print("👋 До свидания!")
            break

if __name__ == "__main__":
    main()
```

