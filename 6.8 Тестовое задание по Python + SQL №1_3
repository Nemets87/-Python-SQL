import sqlite3
# Берём библиотеку для работы с SQLite. Это как нанять специалмста, который знает язык баз данных.

# ----------------------------------------------------
# 1. Подключение к базе данных и инициализация таблицы
# ----------------------------------------------------
DB_NAME = 'registration.db'

# Используем контекстный менеджер для автоматического закрытия соединения
# Конструкция with гарантирует, что после выхода из блока соединение закроется.
with sqlite3.connect(DB_NAME) as db:
    #  создаём курсор. Это наша «рука робота аля указка», которая будет писать запросы и забирать результаты.
    cur = db.cursor()

    # Создаём таблицу, если её ещё нет
    # «создай, только если такой таблицы ещё нет». Это позволяет запускать программу сколько угодно раз,
    # таблица не будет дублироваться.
    # AUTOINCREMENT гарантирует, что даже если мы удалим пользователя, его номер не будет использован повторно.
    # Это как табельный номер участника регаты.
    # UNIQUE на уровне базы не даст вставить два одинаковых логина,
    cur.execute("""
        CREATE TABLE IF NOT EXISTS users_data (
            UserID INTEGER PRIMARY KEY AUTOINCREMENT,
            Login TEXT NOT NULL UNIQUE,
            Password TEXT NOT NULL,
            Code TEXT NOT NULL
        );
    """)
    print("✅ База данных и таблица готовы.")

    # --------------------------------------------------------------
    # 2. Добавление начального пользователя Ivan (если не существует)
    # --------------------------------------------------------------
    # Поскольку логин должен быть регистронезависимым, проверяем по LOWER()
    # Каждый раз при запуске программы мы не хотим добавлять Ивана заново.
    # Поэтому мы сначала спрашиваем базу: «Есть ли уже пользователь с логином Ivan?». 
    cur.execute("SELECT COUNT(*) FROM users_data WHERE LOWER(Login) = LOWER(?)", ('Ivan',))
    if cur.fetchone()[0] == 0:
        # забираем первую ячейку результата (количество), и если оно равно 0, значит, Ивана ещё нет.
        cur.execute(
            "INSERT INTO users_data (Login, Password, Code) VALUES (?, ?, ?)",
            # (?, ?, ?) – параметризованный запрос.
            ('Ivan', 'qwer1234', '1234')
        )
        print("👤 Начальный пользователь 'Ivan' добавлен.")
    else:
        print("👤 Пользователь 'Ivan' уже существует.")

# --------------------------------------------------------------
# 3. Функции для операций
# --------------------------------------------------------------

def register_user(login, password, code):
    """Регистрация нового пользователя."""
    # Проверка на пустые поля
    if not login or not password or not code:
        print("❌ Все поля обязательны для заполнения!")
        # В Python пустая строка считается ложью. Если хотя бы одно поле не заполнено, мы сразу отказываем.
        return False

    # Подключение (можно было бы использовать одно подключение, но для ясности откроем заново)
    with sqlite3.connect(DB_NAME) as db:
        # with – каждое обращение к базе изолировано
        cur = db.cursor()
        # Проверка уникальности логина (регистронезависимо)
        cur.execute("SELECT COUNT(*) FROM users_data WHERE LOWER(Login) = LOWER(?)", (login,))
        # LOWER() – снова регистронезависимая проверка. Если пользователь с таким логином уже есть, регистрация невозможна.
        if cur.fetchone()[0] > 0:
            print("❌ Пользователь с таким логином уже существует!")
            return False

        # Вставка новой записи
        cur.execute(
            "INSERT INTO users_data (Login, Password, Code) VALUES (?, ?, ?)",
            (login, password, code)
        )
        print("✅ Регистрация прошла успешно!")
        return True


def authorize_user(login, password): # пароль сравнивается точно, включая регистр
    # Запрос с двумя параметрами – мы ищем запись, где логин (без учёта регистра) и пароль (строго как введён) совпадают.
    """Авторизация пользователя."""
    with sqlite3.connect(DB_NAME) as db:
        cur = db.cursor()
        # Ищем пользователя по логину (без учёта регистра) и точному паролю
        cur.execute(
            "SELECT * FROM users_data WHERE LOWER(Login) = LOWER(?) AND Password = ?",
            (login, password)
        )
        user = cur.fetchone()
        # fetchone() – забираем одну строку. Если она есть (if user), значит, пользователь найден.
        if user:
            # выводим имя пользователя (user[1] – это столбец Login, потому что нумерация с 0: UserID – 0, Login – 1, и т.д.).
            print(f"✅ Добро пожаловать, {user[1]}!")
            return True
        else:
            print("❌ Неверный логин или пароль!")
            return False

# Функция восстановления пароля recover_password
def recover_password(login, code):
    """Восстановление пароля по коду."""
    with sqlite3.connect(DB_NAME) as db:
        cur = db.cursor()
        # Ищем пользователя по логину (регистронезависимо) и коду
        cur.execute(
            "SELECT UserID, Login FROM users_data WHERE LOWER(Login) = LOWER(?) AND Code = ?",
            (login, code)
        )
        user = cur.fetchone()
        if not user:
            print("❌ Неверный логин или код!")
            return False

        # Запрашиваем новый пароль
        new_password = input("Введите новый пароль: ")
        if not new_password:
            print("❌ Пароль не может быть пустым!")
            return False

        # Обновляем пароль в базе
        cur.execute(
            "UPDATE users_data SET Password = ? WHERE UserID = ?",
            # Мы используем UserID, потому что это надёжнее: вдруг у двух разных пользователей одинаковый код?
            # (Хотя код у нас и не уникален, но мы не должны менять пароль не тому.)
            (new_password, user[0])
        )
        print("✅ Пароль успешно изменён!")
        return True


# --------------------------------------------------------------
# 4. Основной цикл взаимодействия с пользователем
# --------------------------------------------------------------
while True:
    # безконечный цикл. Программа будет работать, пока пользователь не выберет выход.
    print("\n" + "=" * 40)
    print("   Меню действий:")
    print("   1 - Регистрация")
    print("   2 - Авторизация")
    print("   3 - Восстановление пароля")
    print("   0 - Выход")
    print("=" * 40)

    choice = input("Выберите действие (0-3): ").strip()

    if choice == '1':
        print("\n--- Регистрация нового пользователя ---")
        login = input("Логин: ").strip()
        password = input("Пароль: ").strip()
        code = input("Код (4 знака): ").strip()
        register_user(login, password, code)

    elif choice == '2':
        print("\n--- Авторизация ---")
        login = input("Логин: ").strip()
        password = input("Пароль: ").strip()
        authorize_user(login, password)

    elif choice == '3':
        print("\n--- Восстановление пароля ---")
        login = input("Логин: ").strip()
        code = input("Код (4 знака): ").strip()
        recover_password(login, code)

    elif choice == '0':
        print("👋 До свидания!")
        break # прерывает цикл

    else:
        print("❌ Неверный ввод. Пожалуйста, введите 0, 1, 2 или 3.")
